  <div class="navbar-container">
    <div class="header-logo">
      <a href="/" rel="home">
        <img src="<%- url_for(theme.avatar, { ignore: true }) %>" alt="<%= config.title %>"></a>
    </div>
    <div class="menu">
      <a class="menu-item" href="/archivo">Archivo</a>
      <a class="menu-item" href="/acerca-de">Acerca de...</a>
    </div>

  </div>
</nav>

<%# mobile %>
<nav class="navbar-mobile" id="nav-mobile" aria-label="Navegación móvil">
  <div class="navbar-container">
    <div class="header-logo">
      <a href="/" rel="home">
        <img src="<%- url_for(theme.avatar, { ignore: true }) %>" alt="<%= config.title %>"></a>
    </div>
    <div class="menu-toggle" role="button" aria-expanded="false" onclick="mobileBtn()">&#9776; menú</div>
    <div class="menu" id="mobile-menu">
      <a class="menu-item" href="/archivo">Archivo</a>
      <a class="menu-item" href="/acerca-de">Acerca de...</a>
    </div>
  </div>
</nav>

<script>
  var mobileBtn = function f() {
    var toggleMenu = document.getElementsByClassName("menu-toggle")[0];
    var mobileMenu = document.getElementById("mobile-menu");
    if(toggleMenu.classList.contains("active")){
       toggleMenu.classList.remove("active")
      mobileMenu.classList.remove("active")
      toggleMenu.setAttribute("aria-expanded", "false")
    }else{
      toggleMenu.classList.add("active")
      mobileMenu.classList.add("active")
      toggleMenu.setAttribute("aria-expanded", "true")
    }
  }
</script>
