.archive
  width: 75%;
  padding-right: 20px;
  
  .post-list
    padding 0 0 0 10px
    margin 0

.archive-item
  margin-left 2rem

.archive-item-link
    display inline-block
    text-decoration none
    overflow hidden
    //text-overflow ellipsis
    white-space nowrap
    &:hover
      color $global-link-hover-color
      background-color transparent
    
  .archive-item-date
    float right
    text-align right
    color $font-secondary-color

